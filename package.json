{
  "name": "flashi",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"vite --host\" \"tsx watch server/index.ts\"",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist-server/index.js",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"server/**/*.ts\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^8.2.2",
    "prettier": "^3.8.2",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5",
    "vite": "^8.0.8"
  }
}
